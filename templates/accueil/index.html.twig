{% extends 'base.html.twig' %}

{% block title %}Dashboard
{% endblock %}

{% block body %}
	<div class="body" data-turbo="false">
		<div class="row">
			<div class="col-lg-3 col-md-6">
				<div class="ibox bg-success color-white widget-stat">
					<div class="ibox-body">
						<h2 class="m-b-5 font-strong">{{ (payees|length) }}</h2>
						<div class="m-b-5">Factures soldées</div>
						<i class="ti-shopping-cart widget-stat-icon"></i>
						<div>
							<a href="{{path('app_boncommande_facture')}}">
								<i class="fa fa-level-up m-r-5"></i>
								<i class="fa fa-level-up m-r-5"></i>
							</a>

							<small></small>
						</div>
					</div>
				</div>
			</div>
			<div class="col-lg-3 col-md-6">
				<div class="ibox bg-info color-white widget-stat">
					<div class="ibox-body">
						<h2 class="m-b-5 font-strong">{{ (bonachats|length) }}</h2>
						<div class="m-b-5">Bon d'achat</div>
						<i class="ti-bar-chart widget-stat-icon"></i>
						<div>
							<a href="{{path('app_boncommande_index2')}}">
								<i class="fa fa-level-up m-r-5"></i>
								<i class="fa fa-level-up m-r-5"></i>
							</a>
							<small></small>
						</div>
					</div>
				</div>
			</div>
			<div class="col-lg-3 col-md-6">
				<div class="ibox bg-warning color-white widget-stat">
					<div class="ibox-body">
						<h2 class="m-b-5 font-strong">{{ (bon|length) }}</h2>
						<div class="m-b-5">Proformas
						</div>
						<i class="fa fa-money widget-stat-icon"></i>
						<div>
							<a href="{{path('app_boncommande_proforma')}}">
								<i class="fa fa-level-up m-r-5"></i>
								<i class="fa fa-level-up m-r-5"></i>
							</a>
							<small></small>
						</div>
					</div>
				</div>
			</div>
			<div class="col-lg-3 col-md-6">
				<div class="ibox bg-danger color-white widget-stat">
					<div class="ibox-body">
						<h2 class="m-b-5 font-strong">{{ (impayees|length) }}</h2>
						<div class="m-b-5">Factures impayées</div>
						<i class="ti-user widget-stat-icon"></i>
						<div>
							<a href="{{path('app_reglement_index')}}">
								<i class="fa fa-level-down m-r-5"></i>
							</a>
							<small></small>
						</div>
					</div>
				</div>
			</div>
		</div>


		<div class="row">
			<div class="col-lg-8">
				<div class="ibox">
					<div class="ibox-head">
						<div class="ibox-title">Demande d'achat en attente</div>
					</div>
					<div class="ibox-body">
						<table class="table table-striped m-t-20 visitors-table">
							<thead>
								<tr>
									<th>Date</th>
									<th>Clients</th>
									<th>Contact</th>
									<th>Code</th>


								</tr>
							</thead>
							<tbody>
								{% for item in bonachats %}
									<tr>

										<td>
											{{ item.datedevis|date('Yd-m-Y') }}
										</td>
										<td>
											{{ item.client.libelle }}
										</td>
										<td>
											{{ item.client.contact1 }}
										</td>
										<td>
											{{ item.codedevis }}
										</td>


									</tr>
								{% else %}
									<tr>
										Accune demande d'achat en attente
									</tr>
								{% endfor %}


							</tbody>
						</table>
					</div>
				</div>
			</div>
			<div class="col-lg-4">
				<div class="ibox">
					<div class="ibox-head">
						<div class="ibox-title">Statistics</div>
					</div>
					<div class="ibox-body">
					
						<ul class="list-group list-group-divider list-group-full">
							<li class="list-group-item">Graphe des quantités demandées
								{{ render_chart(chart, {'class': 'my-chart'}) }}
							</li>
						
						</ul>
					</div>
				</div>
			</div>
		</div>
		<div class="row"></div>
		<div class="row">
			<div class="col-lg-8">
				<div class="ibox">
					<div class="ibox-head">
						<div class="ibox-title">Proforma en attente de confirmation</div>
						<div class="ibox-tools">
							<a class="ibox-collapse">
								<i class="fa fa-minus"></i>
							</a>
							<a class="dropdown-toggle" data-toggle="dropdown">
								<i class="fa fa-ellipsis-v"></i>
							</a>

						</div>
					</div>
					<div class="ibox-body">
						<table class="table table-striped table-hover">
							<thead>
								<tr>
									<th width="91px">Date edition</th>

									<th>Code Facture</th>
									<th>Client</th>
									<th>Montant HT</th>
									<th>Montant remise</th>
									<th>Tva</th>
									<th>Net à payer</th>

								</tr>
							</thead>
							<tbody>
								{% for item in proformas %}
									<tr>


										<td>
											{{ item.dateproforma|date('d-m-Y') }}
										</td>
										<td>
											{{ item.codeproforma }}
										</td>
										<td>{{ item.client.libelle }}
										</td>
										<td>{{ item.montantht|number_format(0, '.', ' ')  }}</td>
										<td>{{ item.montantremise|number_format(0, '.', ' ')  }}</td>
										<td>{{ item.tva|number_format(0, '.', ' ')  }}</td>
										<td>{{ item.ttc|number_format(0, '.', ' ')  }}</td>

										<td>
											

										</td>


									</tr>
								{% endfor %}

							</tbody>
						</table>
					</div>
				</div>
			</div>
			<div class="col-lg-4">
				<div class="ibox">
					<div class="ibox-head">
						<div class="ibox-title">Articles les plus demandés</div>
					</div>
					<div class="ibox-body">
						<ul class="media-list media-list-divider m-0">
							{% for article in articles %}
								
						
							<li class="media">
								<a class="media-img" href="javascript:;">
							

										{% if article.brochureFilename is not empty %}  <img src="{{ asset('uploads/brochures/'~article.brochureFilename )}}" width="50px;"/> </a> {% else %} {% endif %}
										
									 
								</a>
								<div class="media-body">
									<div class="media-heading">
										<a href="javascript:;">{{ article.libellefr }}</a>
										<span class="font-16 float-right">{{ article.quantitevente|number_format(0, '.', ' ') }}</span>
									</div>
									<div class="font-13">{{ article.marque ? article.marque.libellefr }}</div>
								</div>
							</li>
	{% endfor %}
						</ul>
					</div>
					<div class="ibox-footer text-center">
						<a href="{{ path('app_article_index') }}">View All Products</a>
					</div>
				</div>
			</div>
		</div>
	</div>
{% endblock %}
