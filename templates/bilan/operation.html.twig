{% extends "base.html.twig" %}

{% block title %}Bilan financiers
{% endblock %}

{% block body %}

	<div class="card card-body">
		<form typeoperation="{{ path('app_bilan_operation') }}" method="POST" data-turbo="false">

			<div class="card card-success">
				<div class="card-header">
					<h3 class="card-title">Bilan financier</h3>
				</div>
				<div class="row">


					<div class="col-md-3">
						{{ form_row(form_recherche.objetdepense , {'label':'Objet : '}) }}
					</div>

					<div class="col-md-3">
						{{ form_row(form_recherche.dateDebut, {'label':'Date debut : '}) }}
					</div>

					<div class="col-md-3">
						{{ form_row(form_recherche.dateFin , {'label':'Date fin : '}) }}
					</div>
				</div>

				<div class="col-md-4">
					<button class="btn btn-lg btn-primary" type="submit">
						Valider
					</button>
				</div>


			</div>
		</div>
	</form>
</div>
<div class="rows">
	{% if app.request.method == 'POST' and depenses |length==0 %}
		Aucune depense trouvée

	{% else %}

		{% if depenses |length >0 %}

			{% for message in app.flashes('success') %}
				<div class="primary">
					{{ message }}
				</div>
			{% endfor %}
			<div class="card-body">
				<h4 class="card-title">Resultats</h4>

				<div class="table-responsive">
					<table id="myTable" class="table table-sm table-bordered table-striped table-hover display" style="width:100%">
						<thead class="bg-primary text-white text-bold">


							<tr>
								<th>Date</th>
								<th>Objet</th>
								<th>Montant</th>
								<th>Detail</th>
								<th>Reçu</th>


							</tr>
						</thead>


					</table>


				</div>
			{% endif %}
		{% endif %}
	{% endblock %}
	{% block javascripts %}
		{{ parent() }}
		 <script type="text/javascript">
			
			    {# function deleteRow(value, libelle){
			
			        $('#id-delete').val(value)
			    }
			
			    function updateRow(value){
			
			         var url = window.location.href+ value+"/edit"
			        document.location.href=url
			    } #}
		function iniTable(){
			        $('#myTable').DataTable({
			            select: true,
			            ordering: true,
			            paging: true,
			            responsive: true,
			            processing: true,
			            serverSide: true,
			            searching: true,
			            ajax: {
			                url: '{{ path("depense_lister") }}',
			                type: 'GET',
			
			            },
			            columns: [
			                 { data: 'datedepense' },
			                { data: 'objetdepense.libelle' },
			                { data: 'montant' },
			                { data: 'detail' }
			               
			          
			             
			
			                // { data: 'salary' },
			                // { data: 'office' }
			            ],
			            columnDefs: [
			     
			                
			             
			                   {	
			                	             targets: 4  ,
							                    data: 'brochureFilename',
							                    className: 'text-center',
							                    render: function (brochure) {
							                        let varchemin =  window.location.origin +"/uploads/brochures/"+brochure;
							                        return '<img src="'+varchemin+'" width="50" height="50" style="text-align:center;">';
							                    }
			                }
			
			              
			            ],
			            layout: {
			                topStart: {
			                    pageLength: {
			                        menu: [5, 10, 25, 50, 100]
			                    },
			                    buttons: {
			                        buttons:['copy','excel', 'pdf','colvis']
			                    }
			
			                }
			            },
			            language: {
			                url: '{{ asset("DataTables/fr-FR.json") }}',
			            }
			        });
			        // $('#myTable').on( 'draw.dt', function () {
			        //     $('#myTable').ajax.reload();
			        //     console.log('load')
			        // } );
			
			        const alerts = document.querySelectorAll('[class*="alert-"]')
			        for (const alert of alerts) {
			            setTimeout( function() {
			                const bootstrapAlert = bootstrap.Alert.getOrCreateInstance(alert);
			                bootstrapAlert.close();
			            }, 3000);
			        }
			
			  
			    }
			
			
			        $(document).ready(function(){
			            iniTable()
			
			        });
	</script>
	--!#}
{% endblock %}
