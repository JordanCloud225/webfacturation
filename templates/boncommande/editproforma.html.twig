{% extends 'base.html.twig' %}

{% block title %}Modification proforma
{% endblock %}

{% block body %}
	<div class="ibox">


		{{ form_start(form) }}

		{% for label, messages in app.flashes(['success', 'warning']) %}
			{% for message in messages %}
				<div class="alert alert-success">

					<div class="text-black">
						{{ message }}
					</div>

				</div>

			{% endfor %}
		{% endfor %}

		<div class="ibox-head">
			<div class="ibox-title">
				<h1>Modification de proforma</h1>
			</div>
		</div>
		<div class="row">
					<div class="form-group col-sm-3">
						<label class="text-size" id="client">Client
						</label>
						{{ form_widget(form.client, {'attr':{'class':'form-control input'}}) }}

					</div>
					<div class="form-group col-sm-3">
						<label class="text-size" id="datecommande">Date
						</label>
						{{ form_widget(form.dateproforma, {'attr':{'class':'form-control input'}}) }}

					</div>
					<div class="form-group col-sm-3">
						<label class="text-size" id="po">PO
						</label>
						{{ form_widget(form.po, {'attr':{'class':'form-control input','readonly': 'readonly',}}) }}

					</div>


					<div class="form-group col-sm-3">
						<label class="text-size" id="jobtitle">Objet
						</label>
						{{ form_widget(form.jobtitle, {'attr':{'class':'form-control input'}}) }}

					</div>
					<div class="form-group col-sm-3">
						<label class="text-size" id="sitelocation">Location Site
						</label>
						{{ form_widget(form.sitelocation, {'attr':{'class':'form-control input'}}) }}

					</div>

						<div class="form-group col-sm-3">
						<label class="text-size" id="delivraydelai">Délai de livraison
						</label>
						{{ form_widget(form.delivraydelai, {'attr':{'class':'form-control input'}}) }}

					</div>
				</div>

		<div class="row">
			<div class="form-group col-sm-3">
				<label class="text-size" id="montantremise">Montant remise
				</label>
				{{ form_widget(form.montantremise, {'attr':{'class':'form-control input'}}) }}

			</div>
			<div class="form-group col-sm-3">
					<label class="text-size" id="tva">Montant théorique
					</label>
				<input class="form-control" type="text" readonly placeholder="Montant TVA " value="{{boncommande.reste}}" name="boncommande.reste" id="boncommande.reste">

					<br>
				</div>
             <div class="form-group col-sm-3">
                <label for="jobtitle">Condition d'offre</label>
                {{ form_widget(form.conditionoffre, {'attr': {'class': 'form-control'}}) }}
            </div>

		</div><br><br>

    {# Section des commandes détaillées #}
    <div >
					<div class="offset-4"><h2>Article, service et quantité désirée</h2></div>  

				{% for child in detailcommande %}
				<div class="row">
                    {% if child.article %}
                        <div class="form-group col-sm-3 offset-3">
                            <label>Article</label>
                            <input class=" form-control input" type="text" readonly value="{{ child.article.libellefr}}">
                        </div>
                        {% else %}
                        <div class="form-group col-sm-3 offset-3">
                            <label>Service</label>
                            <input class=" form-control input" type="text" readonly value="{{ child.service.libellefr }}">
                        </div>
                    {% endif %}
                    <div class="form-group col-sm-3">
                        <label>Quantite</label>
                        <input class=" form-control input" type="text" readonly value="{{ child.quantite }}">
					</div>
                </div>
			{% endfor %}

			<span></span>
   		</div>


		<div class="row">
	        <div class="col-md-3 offset-4">
				<button type="submit" class="btn btn-success fa fa-check">Enregistrer </button>
			</div>
            <div class="col-md-3">
				<a href="{{ path('app_boncommande_proforma') }}" class="btn btn-primary fa fa-list">Retour à la liste</a>
			</div>

		</div>
			{{ form_end(form) }}
	</div>
{% endblock %}
{% block javascripts %}
	{{ parent() }}
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Initialisation de la collection
        const collection = document.querySelector("#detailcommandes");
        const span = collection.querySelector("span");

        // Bouton d'ajout
        const boutonAjout = document.createElement("button");
        boutonAjout.className = "ajout-detailcommande btn btn-warning btn-sm ms-2";
        boutonAjout.innerText = "Ajouter un article";
        span.append(boutonAjout);

        collection.dataset.index = collection.querySelectorAll("input").length;

        // Bouton de vérification
        const verifyButton = document.createElement("button");
        verifyButton.type = "button";
        verifyButton.className = "btn btn-secondary btn-sm ms-2";
        verifyButton.innerText = "Recapitulatif";
        verifyButton.id = "verify-da";
        span.append(verifyButton);

        // Événements
        boutonAjout.addEventListener("click", () => addButton(collection));
        verifyButton.addEventListener("click", verifyArticles);
        initDeleteButtons();
    });

    function addButton(collection) {
        const prototype = collection.dataset.prototype;
        const index = collection.dataset.index;
        const newPrototype = prototype.replace(/__name__/g, index);

        const tempDiv = document.createElement("div");
        tempDiv.innerHTML = newPrototype;
        const newForm = tempDiv.firstElementChild;

        const listItem = document.createElement("li");
        listItem.className = "d-flex align-items-center mb-2";

        // Ajout des champs
        listItem.appendChild(newForm.querySelector("[name*='[article]']"));
        listItem.appendChild(newForm.querySelector("[name*='[quantite]']"));

        // Bouton de suppression
        const boutonSuppr = document.createElement("button");
        boutonSuppr.type = "button";
        boutonSuppr.className = "btn btn-danger btn-sm ms-2 remove-item";
        boutonSuppr.innerText = "Supprimer";

        listItem.appendChild(boutonSuppr);
        collection.querySelector("ul").appendChild(listItem);
        collection.dataset.index++;

        // Gestionnaire de suppression
        boutonSuppr.addEventListener("click", function() {
            this.closest('li').remove();
        });
    }

    function initDeleteButtons() {
        document.querySelectorAll('.remove-item').forEach(button => {
            button.addEventListener('click', function() {
                const listItem = this.closest('li');
                const itemId = listItem.dataset.id;
                const deleteUrl = this.dataset.deleteUrl;

                if (itemId && deleteUrl) {
                    // Suppression AJAX pour les éléments existants
                    if (confirm('Voulez-vous vraiment supprimer cet article ?')) {
                        fetch(deleteUrl, {
                            method: 'DELETE',
                            headers: {
                                'X-Requested-With': 'XMLHttpRequest',
                                'Content-Type': 'application/json',
                            },
                        })
                        .then(response => response.json())
                        .then(data => {
                            if (data.success) {
                                listItem.remove();
                            } else {
                                alert('Erreur lors de la suppression');
                            }
                        })
                        .catch(error => console.error('Error:', error));
                    }
                } else {
                    // Suppression simple pour les nouveaux éléments
                    listItem.remove();
                }
            });
        });
    }

    function verifyArticles() {
        const articles = [];
        
        document.querySelectorAll("#detailcommandes li").forEach(item => {
            const article = item.querySelector("[name*='[article]']").value;
            const quantite = item.querySelector("[name*='[quantite]']").value;
            
            if (article) {
                articles.push({
                    article: article,
                    quantite: quantite || 1
                });
            }
        });

        if (articles.length === 0) {
            alert("Veuillez ajouter au moins un article");
            return;
        }

        $.ajax({
            url: "{{ path('verify_DA') }}",
            type: "POST",
            dataType: "json",
            data: JSON.stringify({ 
                articles: articles,
                _token: "{{ csrf_token('verify_da') }}"
            }),
            contentType: "application/json",
            beforeSend: function() {
                Swal.fire({
                    title: 'Opérations en cours',
                    html: 'Patientez pendant que nous traitons votre demande...',
                    allowOutsideClick: false,
                    didOpen: () => Swal.showLoading()
                });
            },
            success: function(response) {
                Swal.close();
                
                if (response.status === 'success') {
                    const formatNumber = num => num.toString().replace(/\B(?=(\d{3})+(?!\d))/g, " ");
                    
                    response.data.forEach(item => {
                        item.prixunitaire = formatNumber(item.prixunitaire);
                        item.quantite = formatNumber(item.quantite);
                        item.totalprix = formatNumber(item.totalprix);
                    });
                    response.total = formatNumber(response.total);

                    let htmlContent = `
                        <table border="1" cellpadding="5" cellspacing="0" style="border-collapse: collapse; width: 100%;">
                            <thead>
                                <tr>
                                    <th>Article</th>
                                    <th>Prix unitaire</th>
                                    <th>Quantité</th>
                                    <th>Total</th>
                                </tr>
                            </thead>
                            <tbody>`;

                    response.data.forEach(item => {
                        htmlContent += `
                            <tr>
                                <td>${item.article}</td>
                                <td>${item.prixunitaire}</td>
                                <td>${item.quantite}</td>
                                <td>${item.totalprix}</td>
                            </tr>`;
                    });

                    htmlContent += `
                            <tr>
                                <td colspan="3" style="text-align: right;"><strong>Total général</strong></td>
                                <td>${response.total}</td>
                            </tr>
                        </tbody>
                    </table>`;
                    
                    Swal.fire({
                        title: 'Tableau récapitulatif',
                        html: htmlContent,
                        icon: 'success',
                        confirmButtonText: 'OK'
                    });
                } else {
                    Swal.fire({
                        title: 'Erreur',
                        text: response.message || 'Une erreur est survenue',
                        icon: 'error'
                    });
                }
            },
            error: function(xhr) {
                Swal.close();
                let errorMsg = "Erreur de connexion au serveur";
                
                try {
                    const jsonResponse = JSON.parse(xhr.responseText);
                    errorMsg = jsonResponse.message || errorMsg;
                } catch (e) {
                    console.error(e);
                }
                
                Swal.fire({
                    title: 'Erreur',
                    text: errorMsg,
                    icon: 'error'
                });
            }
        });
    }
</script>
{% endblock %}
