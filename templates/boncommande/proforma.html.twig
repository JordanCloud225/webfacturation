{% extends 'base.html.twig' %}

{% block title %}Factures proformas
{% endblock %}

{% block body %}
	{% for label, messages in app.flashes(['success', 'warning']) %}
		{% for message in messages %}
			<div class="alert alert-success">

				<div class="text-black">
					{{ message }}
				</div>

			</div>

		{% endfor %}
	{% endfor %}
	<div class="modal fade" id="staticBackdrop-delete" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="staticBackdropLabel" aria-hidden="true">
		<div class="modal-dialog modal-dialog-centered">
			<div class="modal-content">
				<div class="modal-header bg-danger">
					<h1 class="modal-title fs-5 text-white" id="staticBackdropLabel">Suppression</h1>
					<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close">
						<i class="fa fa-close"></i>
					</button>
				</div>
				<form method="post" action="{{ path('app_boncommande_delete') }}" id="form-delete">
					<div class="modal-body container">

						<div class="form-group col-md-12 col-sm-12">
							<input type="hidden" class="form-control p-3" id="id-delete" name="id-delete" placeholder="id commune">
						</div>
						<div class="form-group col-md-12 col-sm-12">
							<label for="libelle" class="label">
								<b style="font-size: large;">Voulez-vous supprimer cet enregistrement ?</b>
							</label><br>
							<span class="text-black-50 p-6"></span>
						</div>


					</div>
					<div class="modal-footer">
						<button type="reset" class="btn btn-sm btn-info" data-bs-dismiss="modal">Non</button>
						<button type="submit" class="btn btn-sm btn-danger" data-bs-dismiss="modal">Oui</button>
					</div>
				</form>
			</div>
		</div>
	</div>


	<h1>Liste Factures Proformas
	</h1>
	<p class="mb-2">
		<a href="{{ path('app_boncommande_new') }}">
			<button class="btn btn-info">
				<i class="fa fa-list"></i>
				Nouveau</button>
		</a>
		<a href="{{ path('app_boncommande_index2') }}">
			<button class="btn btn-success">
				<i class="fa fa-list"></i>
				Demandes d'achat</button>
		</a>
		<a href="{{ path('app_boncommande_index') }}">
			<button class="btn btn-success">
				<i class="fa fa-list"></i>
				Bons de commande</button>
		</a>
		   <a href="{{ path('app_reglement_index') }}"><button class="btn btn-danger"><i class="fa fa-list"></i> Reglement Factures</button></a>

	</p>
	<table id="example-table" class="table table-sm table-bordered table-striped table-hover display" style="width:100%">
		<thead class="bg-primary text-white text-bold">
			<tr>

				<th>Date edition</th>
				<th>Code Facture</th>
				<th>PO</th>
				<th>Objet</th>
				<th>Location Site</th>
				<th>Client</th>
				<th>Montant HT</th>
				<th>Montant remise</th>
				<th>Tva</th>
				<th>Net à payer</th>
				<th data-formater="">Action</th>
			</tr>
		</thead>

	</table>


{% endblock %}
{% block javascripts %}
	{{ parent() }}
	 <script type="text/javascript">
	
	    function deleteRow(value, libelle){
	
	        $('#id-delete').val(value) 
	    }
		function nextRow(value){ 
	         
	         var url =window.location.origin +"/boncommande/" + value+ "/edit"
	        document.location.href=url
	    }
	    function updateRow(value){ 
	         
	         var url =window.location.origin +"/boncommande/" + value+ "/editproforma"
	        document.location.href=url
	     
	    }
		function printRow(value) {
    // Afficher une boîte de dialogue pour demander les préférences d'impression
    Swal.fire({
        title: 'Options d\'impression',
        html:
            '<div class="mb-3">' +
            '   <label for="swal-header" class="form-label">Inclure un en-tête ?</label>' +
            '   <select id="swal-header" class="form-select">' +
            '       <option value="true">Oui</option>' +
            '       <option value="false">Non</option>' +
            '   </select>' +
            '</div>' +
            '<div>' +
            '   <label for="swal-footer" class="form-label">Inclure un pied de page ?</label>' +
            '   <select id="swal-footer" class="form-select">' +
            '       <option value="true">Oui</option>' +
            '       <option value="false">Non</option>' +
            '   </select>' +
            '</div>',
        focusConfirm: false,
        showCancelButton: true,
        confirmButtonText: 'Imprimer',
        cancelButtonText: 'Annuler',
        preConfirm: () => {
            return {
                header: document.getElementById('swal-header').value === 'true',
                footer: document.getElementById('swal-footer').value === 'true'
            }
        }
    }).then((result) => {
        if (result.isConfirmed) {
            // Construire l'URL avec les paramètres
            var url = window.location.origin + "/boncommande/" + value + "/printproforma?" + 
                      "header=" + result.value.header + "&footer=" + result.value.footer;
            
            // Rediriger vers l'URL
            window.open(url, '_blank');
        }
    });
}


	    function iniTable(){
	        $('#example-table').DataTable({
	            select: true,
	            ordering: true,
	            paging: true,
	            responsive: true,
	            serverSide: true,
	            searching: true,
	            ajax: {
	                url: '{{ path("boncommande_proforma") }}',
	                type: 'GET',
	
	            }, 
	            columns: [
	                
	                { data: 'dateproforma' },
	                { data: 'codeproforma' },
					{ data: 'po'},
	                { data: 'jobtitle' },
	                { data: 'sitelocation' },
	                { data: 'client.libelle' },
	                { data: 'montantht' },
	                { data: 'montantremise' },
	                { data: 'tva' },
	                { data: 'ttc' }
	            
	              
	
	                // { data: 'salary' },
	                // { data: 'office' }
	            ],
	            
	            columnDefs: [
	                {
	                    targets: 10,
	                    data: 'id',
	                 render: function (data, type, row, meta) {
    						return '<button class="update btn btn-success" onClick="javascript:nextRow('+ data + ')" title="Transformer en proforma"><i class="fa fa-forward"></i></button>\n\
	                        	                <button class="btn btn-primary" onClick="javascript:printRow('+ data + ')" title="Imprimer" data-bs-target="#" ><i class="fa fa-print"></i></button>\n\
	                        	                <button class="btn btn-warning" onClick="javascript:updateRow('+ data + ')" title="Imprimer" data-bs-target="#" ><i class="fa fa-edit"></i></button>\n\
			                <button class="btn btn-danger" onClick="javascript:deleteRow('+ data + ')" title="Supprimer" data-bs-toggle="modal" data-bs-target="#exampleModal"><i class="fa fa-trash"></i></button>';
		                    }
	                }
	            ],
	            layout: {
	                topStart: {
	                    pageLength: {
	                        menu: [5, 10, 25, 50, 100]
	                    },
	                    buttons: {
	                        buttons:['copy','excel', 'pdf','colvis']
	                    }
	
	                }
	            },
	            language: {
	                url: '{{ asset("DataTables/fr-FR.json") }}',
	            }
	        });
	      
	
	        const alerts = document.querySelectorAll('[class*="alert-"]')
	        for (const alert of alerts) {
	            setTimeout( function() {
	                const bootstrapAlert = bootstrap.Alert.getOrCreateInstance(alert);
	                bootstrapAlert.close();
	            }, 3000);
	        }
	
	  
	    }
	
	
	        $(document).ready(function(){
	            iniTable()
	
	        });
	</script>

{% endblock %}
