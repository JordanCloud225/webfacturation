<!doctype html>
<html>
	<head>
		<meta charset="UTF-8">
		<title>Impression Devis</title>

	
		<style type="text/css">
			* {
				font-family: Verdana, Arial, sans-serif;
			}
			table {
				font-size: x-small;
			}
			tfoot tr td {
				font-weight: bold;
				font-size: x-small;
			}

			.gray {
				background-color: lightgray
			}
			  span {  font-size: 10pt;  }
		</style>
		<style>
			footer {
				position: fixed;
				bottom: -60px;
				left: 0;
				right: 0;
				height: 60px;
				 font-size: x-small; 
				/** Extra personal styles **/

				color: black;
				text-align: center;
				line-height: 15px;
			}
						.entete {
				border: 2px solid black;
				border-collapse: collapse;
				padding: 10px auto;
			}
			.total {
				border: 2px solid black;
				border-collapse: collapse;
				padding: 25px auto;
				font-size: 13pt;
			}
			.ligne {
				padding: 3px auto;
				border-right: 2px solid black;
				border-collapse: collapse;
			}
			.bordure {
				border: 3px solid black;
				border-collapse: collapse;
			}
			.tete {
				text-transform: capitalize;
				font-weight: bold;
			}
			.titre {
				font-style: italic;
				margin: 0 0 0 500px;
			}
			.corps {
				text-transform: capitalize;
				font-style: italic; 
				color : black;
			}
			.direction {
				font-weight: bold;
				font-size: 10pt;
				text-decoration: underline;
			}
		</style>

	</head>
	<body>

		<table width="100%">
			<tr>
				{% if header == 'true' %}
					<td valign="top"><img src="{{ base64(absolute_url(asset('uploads/brochures/header.png' ))) }}" style="img {  border: 1px solid #ddd; border-radius: 4px;  margin: -40px 0 0 -20px ;  width:750px; }" alt="logo">
				</td>
				{% elseif header == 'false' %}
					<br><br><br>
				{% endif %}
			</tr>
		</table>

			<table width="100%" style="margin: 0 0 0 0px;">
			<tr>
				<td class="titre" align="center" colspan="2" >DEVIS POUR Mr/Mme <span class="tete">{{ client|upper }}</span></td>
			</tr>
			<tr>
				<td class="tete" >N° de Devis</td>
				<td align="right" class="tete">Date du Devis</td>
			</tr>
			<tr>
				<td class="corps">{{ boncommandes.codedevis }}</td>
				<td class="corps" align="right"> {{ boncommandes.datedevis|format_datetime('full', 'none', locale: 'fr') }}</td>
			</tr>
		</table>

		<br/>

<table width="100%" style="border-collapse: collapse;">
			<thead >
				<tr class="entete">
					<th class="entete" width="350px">DESIGNATION</th>
					<th class="entete" width="60px">QUANTITE</th>
					<th class="entete" width="80px">PRIX UNIT</th>
				</tr>
			</thead>
			<tbody style="border: 2px solid black; border-collapse: collapse;">
				{% set count = 0 %}
				{% for detailcommande in boncommandes.detailcommandes %}
					{% set qte = detailcommande.quantite %}
					{% set count = count + 1 %}
						{% if qte == 0 %}
						{% else %}
							{% if detailcommande.article %}
								<tr>
									<td class="ligne" >
									<span style='margin: 0 0 0 10px' >*{{ detailcommande.article.libellefr|capitalize  }}</span>
									<br>
									<span style='margin: 0 0 0 40px' >{{ detailcommande.article.detailarticle|raw  }}</span>
									</td>
									<td align="center" class="ligne">{{ detailcommande.quantite }}</td>
									<td align="center" class="ligne">{{ detailcommande.prixunitaire|number_format(0, '.', ' ') }}</td>
								</tr>
							{% else %}
								<tr>
									<td class="ligne" >
									<span style='margin: 0 0 0 10px' >*{{ detailcommande.service.libellefr|capitalize  }}</span>
									<br>
									<span style='margin: 0 0 0 40px' >{{ detailcommande.service.detailservice|raw  }}</span>
									</td>
									<td align="center" class="ligne">{{ detailcommande.quantite }}</td>
									<td align="center" class="ligne">{{ detailcommande.prixunitaire|number_format(0, '.', ' ') }}</td>
								</tr>
							{% endif %}
						{% endif %}
				{% endfor %}
			</tbody>
			<tfoot>
				<tr >
					<td colspan="1" style="border-bottom: none;"></td>
					<td align="center" colspan="2" class="total">TOTAL NET : 

					{% set soustotal = 0 %}

					{% for detailcommande in boncommandes.detailcommandes %}
						{% set prixunitaire = detailcommande.prixunitaire %}
						{% set qte = detailcommande.quantite %}

						{% set prixtotal = qte * prixunitaire  %}
						{% set soustotal = prixtotal + soustotal ?? 0   %}
						{% if loop.last %}


							{% set var = (soustotal - boncommandes.montantremise) + boncommandes.tva  %}
								{{ var|number_format(0, '.', ' ') }}
							</td>
						{% endif %}
					{% endfor %}
				</tr>
			</tfoot >
		</table>
		<br>
		<table width="90%">

			<tr align="right">
				<td class="direction">
					LA DIRECTION
				</td>
			</tr>
		</table>
	<footer>
			{% if footer == 'true' %}
				<img src="{{ base64(absolute_url(asset('uploads/brochures/footer.png' ))) }}" style="img { border: 1px solid #ddd; border-radius: 4px;  margin: -40px 0 0 -20px ;  width:750px; }" alt="logo">
			{% elseif footer == 'false'  %}
					
			{% endif %}
	</footer>
	
		<br/>

	</body>
</html>
 
			
