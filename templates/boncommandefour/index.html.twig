		{#                    <a href="{{ path('app_fournisseur_show', {'id': fournisseur.id}) }}" title="Supprimer"><button class="btn btn-sm btn-danger"><i class="fa fa-trash"></i></button></a>onclick="return confirm('Are you sure you want to delete this item?');"#}
		{#                    <a href="{{ path('app_fournisseur_delete', {'id': fournisseur.id}) }}"  title="Supprimer">#}
