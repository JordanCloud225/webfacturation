{% endblock %}
{% block javascripts %}
	{{ parent() }}
	 <script type="text/javascript">
	
	    function deleteRow(value, libelle){
	
	        $('#id-delete').val(value)
	    }
	
	    function updateRow(value){
	
	         var url = window.location.origin+ "/boncommandefour/" + value + "/edit"
	        document.location.href=url
	    }
	    function iniTable(){
	        $('#example-table').DataTable({
                debug: true, 
	            select: true,
	            ordering: true,
	            paging: true,
	            processing: true,
	            serverSide: true,
	            searching: true,
	            ajax: {
	                url: '{{ path("bdcfour_lister") }}',
	                type: 'GET',
	
	            },
	            columns: [
                    { data: 'fournisseur.libelle' },
	                { data: 'datebdc' },
	                //{ data: 'datebdccli' },	              
	            ],
	            columnDefs: [
	                {
	                    targets: 2,
	                    data: 'id',
	                    render: function (data, type, row, meta) {
	                        return '<button class="update btn btn-success" onClick="javascript:updateRow('+ data + ')" title="Modifier"><i class="fa fa-edit"></i></button>\n\
	                <button class="btn btn-danger" onClick="javascript:deleteRow('+ data + ')" title="Supprimer" data-bs-toggle="modal" data-bs-target="#exampleModal"><i class="fa fa-trash"></i></button>';
	                    }
	                }
	            ],
	            layout: {
	                topStart: {
	                    pageLength: {
	                        menu: [5, 10, 25, 50, 100]
	                    },
	                    buttons: {
	                        buttons:['copy','excel',  'print', 'pdf','colvis']
	                    }
	
	                }
	            },
	            language: {
	                url: '{{ asset("DataTables/fr-FR.json") }}',
	            }
	        });
	        // $('#example-table-table-table').on( 'draw.dt', function () {
	        //     $('#example-table-table-table').ajax.reload();
	        //     console.log('load')
	        // } );
	
	        const alerts = document.querySelectorAll('[class*="alert-"]')
	        for (const alert of alerts) {
	            setTimeout( function() {
	                const bootstrapAlert = bootstrap.Alert.getOrCreateInstance(alert);
	                bootstrapAlert.close();
	            }, 3000);
	        }
	  
	    }

	
	        $(document).ready(function(){
	            iniTable()
	
	        });
	</script>
{% endblock %}
