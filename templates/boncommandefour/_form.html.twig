  <div class="ibox-body">
{{ form_start(form) }}

    {% for label, messages in app.flashes(['success', 'warning']) %}
        {% for message in messages %}
            <div class="alert alert-success">

                    <div class="text-black">
                        {{ message }}
                    </div>

            </div> 

        {% endfor %}
    {% endfor %}
  
    <div class="row">
      <div class="form-group col-sm-6">
          <label class="text-size" id="client">Fournisseur </label>
              {{ form_widget(form.fournisseur, {'attr':{'class':'form-control input','placeholder':'Nom Fournisseur'}}) }}
          <br>
      </div>
        <div class="form-group col-sm-6">
          <label class="text-size" id="datebdccli">Date * </label>
              {{ form_widget(form.datebdc, {'attr':{'class':'form-control input','placeholder':'Ville du client'}}) }}
          <br>
      </div> 
          
         <div class="form-group col-sm-5 offset-3">
          <label class="text-size" id="brochure">Brochure </label>
              {{ form_widget(form.brochure, {'attr':{'class':'form-control input','placeholder':'Devis du Fournisseur'}}) }}
          <br>
      </div>
      </div>

 
      <div class="row"> 
          <div class="col-md-2">
      {{ form_row(form.save, {'label':'Enregistrer ','attr':{'value':'save', 'class':'btn bt-md btn-success fa fa-save'}}) }}</div>
           <div class="col-md-2">
      {{ form_row(form.saveAndAdd, {'label':'Enregistrer ++ ','attr':{'value':'saveAndAdd', 'class':'btn btn-success fa fa-save '}}) }}</div>
          <div class="col-md-2">
          <a href="{{ path('app_client_index') }}" class="btn btn-primary fa fa-list">Afficher la liste</a> </div>

      </div>
{{ form_end(form) }}
   </div>
