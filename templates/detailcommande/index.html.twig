{% extends 'base.html.twig' %}

{% block title %}Detailcommande index{% endblock %}

{% block body %}
    <h1>Detailcommande index</h1>
 <a href="{{ path('app_detailcommande_new') }}">Create new</a>
    <table class="table">
        <thead>
            <tr>
              
                <th>Date</th>
                <th>Article</th>
                <th>Prix unitaire</th>
                <th>Quantite</th>
              <th>Sous total</th>

                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for detailcommande in detailcommandes %}
            <tr>
             
                <td>{{ detailcommande.datedetail ? detailcommande.datedetail|date('d-m-Y') : '' }}</td>
                <td>{{ detailcommande.article ?  detailcommande.article.libellefr  }}</td>
                <td>{{ detailcommande.prixunitaire }}</td>
                <td>{{ detailcommande.quantite }}</td>
                <td>{{ detailcommande.soustotal }}</td>
    
                <td>
                    <a href="{{ path('app_detailcommande_show', {'id': detailcommande.id}) }}">show</a>
                    <a href="{{ path('app_detailcommande_edit', {'id': detailcommande.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="13">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

   
{% endblock %}
