{% extends 'accueil/index.html.twig' %}

{% block title %}Creation User{% endblock %}

{% block body %}
<div class="container">
    <div class="form-group row">
        <div class="col-sm-12">
            <h1 class="text-black">Création Utilisateur</h1>
        </div>
    </div>

    <div class="card card-body">
        {{ form_start(form) }}
        <div class="my-custom-class-for-errors">
            {{ form_errors(form) }}
            {% for message in app.flashes('message') %}
                <div class="primary">
                    {{ message }}
                </div>
            {% endfor %}
  
        </div>

    <div class="row">
       <div class="form-group col-sm-6">

            {{ form_row(form.email, {'label':'Email * ','attr':{'class':'form-control'}}) }}
        </div>
          <div class="form-group col-sm-6">

            {{ form_row(form.nom, {'label':'Nom * ','attr':{'class':'form-control'}}) }}
        </div>
            <div class="form-group col-sm-6">

            {{ form_row(form.contact, {'label':'N° Téléphone  ','attr':{'class':'form-control'}}) }}
        </div>
     
    
         <div class="form-group col-sm-6">

            {{ form_row(form.roles, {'label':'Role * ','attr':{'class':'form-control'}}) }}
        </div>
            <div class="form-group col-sm-6">

            {{ form_row(form.plainPassword, {'label':'Mot de passe * ','attr':{'class':'form-control'}}) }}
        </div>
           <div class="form-group col-sm-6">

            {{ form_row(form.brochure, {'label':'Photo profile  ','attr':{'class':'form-control'}}) }}
        </div>
    </div>


    <div class="col-md-6">
        <button class="btn btn-success">{{ button_label|default('Valider') }}</button>
    </div>










    {{ form_end(form) }}
    </div>
{% endblock %}
