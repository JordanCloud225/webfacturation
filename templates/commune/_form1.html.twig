
<div class="card card-primary">

    <div class="card card-body">
       
       {{ form_start(form) }}
        <div class="my-custom-class-for-errors">
            {{ form_errors(form) }}
            {% for message in app.flashes('commune') %}
                <div class="primary">
                    {{ message }}
                </div>
            {% endfor %}
   
        </div>
        <div class="row">
            <div class="col-md-3">
                {{ form_row(form.nom, {'label':'Commune ', 'attr':{'class':'form-control'}}) }}
            </div>
            
        </div>


        <div class="row"> 
            <div class="col-md-1">{{ form_row(form.save, {'label':'Valider ','attr':{'value':'save'}}) }}</div>
            <div class="col-md-2"> {{ form_row(form.saveAndAdd, {'label':'Valider et continuer ','attr':{'value':'save-and-add'}}) }} </div>
            <div class="col-md-3"><a href="{{ path('commune') }}" class="btn btn-success">Afficher la liste</a> </div>
        </div> 
        {{ form_end(form) }}

    </div>
</div>