<div class="ibox-body">
{{ form_start(form) }}
    {% for label, messages in app.flashes(['success', 'warning']) %}
        {% for message in messages %}
            <div class="alert alert-success">

                    <div class="text-black">
                        {{ message }}
                    </div>

            </div> 

        {% endfor %}
    {% endfor %}
    <div class="row ">
      <div class="form-group col-sm-5 offset-1">
          <label class="text-size" id="libelle">Libelle </label>
              {{ form_widget(form.libelle, {'attr':{'class':'form-control input'}}) }}
        </div>
        <div class="form-group col-sm-5">
          <label class="text-size" id="libelle">Valeur Libelle </label>
              {{ form_widget(form.valeurlibelle, {'attr':{'class':'form-control input'}}) }}
          <br>
      </div>
      <div class="row"> 
          <div class="col-md-2 offset-3">
      {{ form_row(form.save, {'label':'Enregistrer ','attr':{'value':'save', 'class':'btn bt-md btn-success fa fa-save'}}) }}</div>
           <div class="col-md-2">
      {{ form_row(form.saveAndAdd, {'label':'Enregistrer ++ ','attr':{'value':'saveAndAdd', 'class':'btn btn-success fa fa-save '}}) }}</div>
          <div class="col-md-2"><a href="{{ path('app_conditionoffre_index') }}" class="btn btn-primary fa fa-list">Afficher la liste</a> </div>
    </div>


{{ form_end(form) }}
      </div>