<!doctype html>
<html>
	<head>
		<title>Impression Facture</title>
			<style type="text/css">
				* {
					font-family: Verdana, Arial, sans-serif;
				}
				table {
					font-size: x-small;
				}
				tfoot tr td {
					font-weight: bold;
					font-size: x-small;
				}

				.gray {
					background-color: lightgray
				}
				.you {
					style="border: 2px solid black; border-collapse: collapse;"
				}
				span {
					font-size: 10pt;
				}
				.entete {
					border: 2px solid black;
					border-collapse: collapse;
					padding: 10px auto;
				}
				.totall {
					border: 2px solid black;
					border-left: none;
					border-collapse: collapse;
					padding: 5px auto;
					font-size: 10pt;
				}
				.totalr {
					border: 2px solid black;
					border-right: none;
					border-collapse: collapse;
					padding: 5px auto;
					font-size: 10pt;
					background-color: black;
					color: white;
				}
				.ligne {
					padding: 3px auto;
					border-right: 2px solid black;
					border-collapse: collapse;
				}
				.bordure {
					border: 3px solid black;
					border-collapse: collapse;
				}
				.tete {
					text-transform: capitalize;
					font-weight: bold;
				}
				.corps {
					text-transform: capitalize;
					font-style: italic; 
					color : gray;
				}
				.direction {
					font-weight: bold;
					font-size: 10pt;
					text-decoration: underline;
				}
			</style>
		<style>
			footer {
				position: fixed;
				bottom: -60px;
				left: 0;
				right: 0;
				height: 60px;
				font-size: x-small;
				/** Extra personal styles **/

				color: black;
				text-align: center;
				line-height: 15px;
	   
               before { content: counter(page); }
			}
		</style>
	</head>
	<body>

		<table width="100%">
			<tr>
				{% if header == 'true' %}
					<td valign="top"><img src="{{ base64(absolute_url(asset('uploads/brochures/header.png' ))) }}" style="img {  border: 1px solid #ddd; border-radius: 4px;  margin: -40px 0 0 -20px ;  width:750px; }" alt="logo">
				</td>
				{% elseif header == 'false' %}
					<br><br><br>
				{% endif %}
			</tr>
		</table>

		<table width="100%">
			<tr>
				<td>
				</td>
				<td align="center">
					<strong>FACTURE N°</strong> {{ reglements.facture.boncommande.codecommande }}-{{ reglements.facture.boncommande.client.libelle }}-{{ reglements.facture.boncommande.client.sigle }}
				</td>
			</tr>
			<tr></tr>
			<tr>
				<td>
				</td>
				<td align="right">
					{{ entreprise.ville }}, {{ reglements.facture.boncommande.dateproforma|format_datetime('full', 'none', locale: 'fr') }}
				</td>
			</tr>
		</table>
	<br>
		<table width="85%" style="margin: 0 0 0 50px;">
			<tr>
				<td class="tete" >{{ entreprise.libelle }}</td>
				<td align="right" class="tete">{{ reglements.facture.boncommande.client.libelle }}</td>
			</tr>
			<tr>
				<td class="corps">{{ entreprise.adresse }}</td>
				<td class="corps" align="right">{{ reglements.facture.boncommande.client ? reglements.facture.boncommande.client.adresse }}</td>
			</tr>
			<tr>
				<td class="corps">{{ entreprise.contact1 }} / {{  entreprise.contact2 }}</td>
				<td class="corps" align="right">{{ reglements.facture.boncommande.client ? reglements.facture.boncommande.client.contact1 }} / {{ reglements.facture.boncommande.client ? reglements.facture.boncommande.client.contact2 }}</td>
			</tr>
			<tr>
				<td class="corps">{{ entreprise.email }} </td>
				<td class="corps" align="right">{{ reglements.facture.boncommande.client ? reglements.facture.boncommande.client.email }}</td>
			</tr>
			<tr>
				<td class="tete">Objet</td>
				<td class="tete" align="right">Adresse de livraison</td>
			</tr>
			<tr>
				<td class="corps">{{ reglements.facture.boncommande.jobtitle }}</td>
				<td class="corps" align="right">{{ reglements.facture.boncommande.sitelocation }}</td>
			</tr>
		</table>
		<br/>
		<table width="100%" style="border-collapse: collapse;">
			<thead >
				<tr class="entete">
					<th class="entete" width="350px">DESIGNATION</th>
					<th class="entete" width="60px">QUANTITE</th>
					<th class="entete" width="105px">U.P XOF</th>
					<th class="entete" width="105px">Total XOF</th>
				</tr>
			</thead>
			<tbody style="border: 2px solid black; border-collapse: collapse;">
				{% set count = 0 %}{% set prixtotal = 0 %}
				{% for detailcommande in reglements.facture.boncommande.detailcommandes %}
					{% set prixunitaire = detailcommande.prixunitaire %}
					{% set prixunitaireuro = prixunitaire / 655.955 %}
					{% set qte = detailcommande.quantite %}
					{% set count = count + 1 %}
					{% set prixtotal = qte * prixunitaire  %}
					{% set prixtotaleuro = prixtotal / 655.955  %}
					{% if qte == 0 %}
					{% else %}
						{% if detailcommande.article %}
							<tr>
								<td align="center" class="ligne" >
									{{ detailcommande.article.libellefr }}
								</td>
								<td align="center" class="ligne">{{ detailcommande.quantite }}</td>
								<td align="center" class="ligne">{{ detailcommande.prixunitaire|number_format(0, '.', ' ') }}</td>
								<td align="center" class="ligne">{{ prixtotal|number_format(0, '.', ' ')  }}</td>
							</tr>
						{% else %}
							<tr>
								<td align="center" class="ligne" >
									{{ detailcommande.service.libellefr }}
								</td>
								<td align="center" class="ligne">{{ detailcommande.quantite }}</td>
								<td align="center" class="ligne">{{ detailcommande.prixunitaire|number_format(0, '.', ' ') }}</td>
								<td align="center" class="ligne">{{ prixtotal|number_format(0, '.', ' ')  }}</td>
							</tr>
						{% endif %}
						
						
					{% endif %}
				{% endfor %}
				</tbody>
			</tbody>
			<tfoot>
				<tr>
					<td colspan="2"></td>
					<td align="center" class="totalr">Sous-total
					</td >

					{% set soustotal = 0 %}

					{% for detailcommande in reglements.facture.boncommande.detailcommandes %}
						{% set prixunitaire = detailcommande.prixunitaire %}
						{% set qte = detailcommande.quantite %}

						{% set prixtotal = qte * prixunitaire  %}
						{% set soustotal = prixtotal + soustotal ?? 0   %}
						{% if loop.last %}


							<td align="center" class="totall">
								{{ soustotal|number_format(0, '.', ' ') }} F CFA ; 
							</td>
						{% endif %}
					{% endfor %}

				</tr>

				<tr>
					<td colspan="2"></td>
					<td align="center" class="totalr">Remise</td>
					<td align="center"  class="totall">
						{% if reglements.facture.boncommande.montantremise is not  empty %}
							{{ reglements.facture.boncommande.montantremise|number_format(0, '.', ' ') }} F CFA ; 
						{% else %}
							00
						{% endif %}
					</td>
				</tr>
				<tr>
					<td colspan="2"></td>
					<td align="center" class="totalr">Montant TVA</td>
					<td align="center" class="totall">
						{{ reglements.facture.boncommande.tva|number_format(0, '.', ' ') }} F CFA ; 
					</td>
				</tr>

				<tr>
					<td colspan="2"></td>
					<td align="center" class="totalr">TOTAL NET</td>

					{% set soustotal = 0 %}

					{% for detailcommande in reglements.facture.boncommande.detailcommandes %}
						{% set prixunitaire = detailcommande.prixunitaire %}
						{% set qte = detailcommande.quantite %}

						{% set prixtotal = qte * prixunitaire  %}
						{% set soustotal = prixtotal + soustotal ?? 0   %}
						{% if loop.last %}

							<td align="center"  class="totall">
								{{ ((soustotal - reglements.facture.boncommande.montantremise) + reglements.facture.boncommande.tva)|number_format(0, '.', ' ') }}F CFA ;

							</td>
						{% endif %}
					{% endfor %}

				</tr>
					<tr>
					<td colspan="2"></td>
					<td align="center" class="totalr">Montant payé</td>
					<td align="center"  class="totall">
						{{ reglements.facture.montantpaye|number_format(0, '.', ' ') }} F CFA ; 
					</td>
				</tr>
					<tr>
					<td colspan="2"></td>
					<td align="center" class="totalr">Reste à payer</td>
					<td align="center"  class="totall">
						{{ reglements.facture.reste|number_format(0, '.', ' ') }} F CFA ; 
					</td>
				</tr>
			</tfoot>
		</table><br>
		<table width="90%">
			<tr>
			<td>
			{% set soustotal = 0 %}{% set a = 0 %}
				{% for detailcommande in reglements.facture.boncommande.detailcommandes %}
					{% set prixunitaire = detailcommande.prixunitaire %}{% set qte = detailcommande.quantite %}{% set prixtotal = qte * prixunitaire  %}{% set soustotal = prixtotal + soustotal ?? 0   %}
					{% if loop.last %}

					<span>Sauf erreur de notre part, la présente  facture N°: {{ reglements.facture.boncommande.codecommande }} d'un montant de :
				
						{% set a =( soustotal - reglements.facture.boncommande.montantremise )+ reglements.facture.boncommande.tva %}
						{{  a|number_format(0, '.', ' ') }}
						F CFA 
								 a été payée à hauteur de : 	 	<b>{{ reglements.facture.montantpaye|number_format(0, '.', ' ') }}
								  </b> {% if reglements.facture.reste > 0 %} il reste	<b> {{ reglements.facture.reste|number_format(0, '.', ' ')  }} F CFA </b>-- 
																
								 {% else %}. <i> Cette facture est soldée </i> {% endif %}
						
					</span>
					{% endif %}
				{% endfor %}
			</td>
			</tr>
			<tr align="right">
				<td class="direction">
					LA DIRECTION
				</td>
			</tr>
		</table>
		<footer>
				{% if footer == 'true' %}
				<img src="{{ base64(absolute_url(asset('uploads/brochures/footer.png' ))) }}" style="img { border: 1px solid #ddd; border-radius: 4px;  margin: -40px 0 0 -20px ;  width:750px; }" alt="logo">
				{% elseif footer == 'false'  %}
					
				{% endif %}
  		</footer>
	</body>

</html>

