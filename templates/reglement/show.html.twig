{% extends 'base.html.twig' %}

{% block title %}Reglement{% endblock %}

{% block body %}
    <h1>Reglement</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ reglement.id }}</td>
            </tr>
            <tr>
                <th>Montantpayee</th>
                <td>{{ reglement.montantpayee }}</td>
            </tr>
            <tr>
                <th>Reste</th>
                <td>{{ reglement.reste }}</td>
            </tr>
            <tr>
                <th>Identreprise</th>
