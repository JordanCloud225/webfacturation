            </tr>
            <tr>
                <th>CreatedBy</th>
                <td>{{ reglement.createdBy }}</td>
            </tr>
            <tr>
                <th>UpdatedBy</th>
                <td>{{ reglement.updatedBy }}</td>
            </tr>
            <tr>
                <th>DeletedBy</th>
                <td>{{ reglement.deletedBy }}</td>
