<div class="ibox-body">
{% block stylesheets %}

    <style>
        .editor-container {
            border: 1px solid #ced4da;
            border-radius: 4px;
            overflow: hidden;
        }
        .editor-toolbar {
            background-color: #f8f9fa;
            padding: 8px;
            border-bottom: 1px solid #ced4da;
            display: flex;
            flex-wrap: wrap;
            gap: 5px;
        }
        .editor-toolbar button {
            background: white;
            border: 1px solid #ced4da;
            border-radius: 4px;
            padding: 5px 10px;
            cursor: pointer;
            transition: all 0.2s;
        }
        .editor-toolbar button:hover {
            background-color: #e9ecef;
        }
        .editor-content {
            min-height: 200px;
            padding: 15px;
            outline: none;
        }
        .hidden-textarea {
            display: none;
        }
        .character-count {
            text-align: right;
            padding: 5px 10px;
            background-color: #f8f9fa;
            border-top: 1px solid #ced4da;
            color: #6c757d;
            font-size: 0.9rem;
        }
    </style>

{% endblock %}
{{ form_start(form)}}

    {% for label, messages in app.flashes(['success', 'warning']) %}
        {% for message in messages %}
            <div class="alert alert-success">

                    <div class="text-black">
                        {{ message }}
                    </div>

            </div> 

        {% endfor %}
    {% endfor %}
    <div class="row">
      <div class="form-group col-sm-4">
          <label class="text-size" id="typeservice">Categorie </label>
              {{ form_widget(form.typeservice, {'attr':{'class':'form-control input','placeholder':'Choix categorie'}}) }}
          <br>
      </div>
       <div class="form-group col-sm-4">
          <label class="text-size" id="prixunitaire">Prix unitaire</label>
              {{ form_widget(form.prixunitaire, {'attr':{'class':'form-control input','placeholder':'Prix unitaire'}}) }}
          <br>
      </div>

        <div class="form-group col-sm-4">
          <label class="text-size" id="prixunitaire">Libellé  </label>
              {{ form_widget(form.libellefr, {'attr':{'class':'form-control input','placeholder':'Libellé'}}) }}
          <br>
      </div>
    <div class="container my-4">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">Détail Service</h5>
                    </div>
                    <div class="card-body">
                            <div class="form-group col-sm-12 mb-4">
                                
                                <!-- Éditeur de texte riche -->
                                <div class="editor-container">
                                    <div class="editor-toolbar">
                                        <button type="button" onclick="formatText('bold')" title="Gras"><strong>G</strong></button>
                                        <button type="button" onclick="formatText('italic')" title="Italique"><em>I</em></button>
                                        <button type="button" onclick="formatText('underline')" title="Souligné"><u>S</u></button>
                                        <button type="button" onclick="insertList('unordered')" title="Liste à puces">•</button>
                                        <button type="button" onclick="insertList('ordered')" title="Liste numérotée">1.</button>
                                    </div>
                                    <div 
                                        class="editor-content" 
                                        id="richEditor" 
                                        contenteditable="true"
                                        oninput="updateCharacterCount()"
                                    ></div>
                                    <div class="character-count">
                                        Caractères: <span id="charCount">0</span>
                                    </div>
                                </div>
                                
                                <!-- Textarea caché pour Symfony -->
                                <textarea 
                                    class="form-control input hidden-textarea" 
                                    id="detailservice" 
                                    name="detailservice" 
                                    rows="10"
                                ></textarea>
                                
                                <small class="form-text text-muted">
                                    Utilisez les boutons ci-dessus pour formater votre texte.
                                </small>
                            </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
      <div class="row"> 
          <div class="col-md-2">
      {{ form_row(form.save, {'label':'Enregistrer ','attr':{'value':'save', 'class':'btn bt-md btn-success fa fa-save'}}) }}</div>
           <div class="col-md-2">
      {{ form_row(form.saveAndAdd, {'label':'Enregistrer ++ ','attr':{'value':'saveAndAdd', 'class':'btn btn-success fa fa-save '}}) }}</div>
          <div class="col-md-2"><a href="{{ path('app_service_index') }}" class="btn btn-primary fa fa-list">Afficher la liste</a> </div>

      </div>
      </div>
{{ form_end(form) }}

      {% block javascripts %}
<script>
        const richEditor = document.getElementById('richEditor');
        const textarea = document.getElementById('detailservice');
        const charCountElement = document.getElementById('charCount');
        
        // Initialiser le compteur de caractères
        updateCharacterCount();
        
        function formatText(format) {
            document.execCommand(format, false, null);
            updateCharacterCount();
            syncWithTextarea();
        }
        
        function insertList(type) {
            if (type === 'unordered') {
                document.execCommand('insertUnorderedList', false, null);
            } else {
                document.execCommand('insertOrderedList', false, null);
            }
            updateCharacterCount();
            syncWithTextarea();
        }
        
        function updateCharacterCount() {
            const text = richEditor.innerText || '';
            const charCount = text.length;
            charCountElement.textContent = charCount;
        }
        
        function syncWithTextarea() {
            // Synchroniser le contenu de l'éditeur avec le textarea caché
            textarea.value = richEditor.innerHTML;
        }
        
        function submitForm() {
            // Synchroniser une dernière fois avant soumission
            syncWithTextarea();
            
            // Afficher le contenu dans la console pour démonstration
            console.log("Contenu HTML:", textarea.value);
            
            // Ici, vous soumettriez normalement le formulaire
            alert("Le formulaire a été soumis! Vérifiez la console pour le contenu HTML.");
        }
        
        // Synchroniser lors de la frappe
        richEditor.addEventListener('input', syncWithTextarea);
        
        // Synchroniser lors de la perte de focus
        richEditor.addEventListener('blur', syncWithTextarea);
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>

{% endblock %}