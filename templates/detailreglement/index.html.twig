{% extends 'base.html.twig' %}

{% block title %}Details reglement
{% endblock %}

{% block body %}
	{% for label, messages in app.flashes(['success', 'warning']) %}
		{% for message in messages %}
			<div class="alert alert-success">

				<div class="text-black">
					{{ message }}
				</div>

			</div>

		{% endfor %}
	{% endfor %}


	<a href="{{ path('app_reglement_index') }}">
		<button class="btn btn-info">
			<i class="fa fa-list"></i>
			Reglements</button>
	</a>
	<table id="example-table" class="table table-sm table-bordered table-striped table-hover display" style="width:100%">
		<thead class="bg-primary text-white text-bold">
			<tr>
				<th>Date Paiement</th>
				<th>N° Facture</th>
				<th>Client</th>
				<th>Contact client</th>
				<th>Montant HT</th>
				<th>Montant remise</th>
				<th>Montant TVA</th>
				<th>Montant TTC</th>
				<th>Montnt payé</th>
				<th>Reste</th>
				<th>Reçu</th>
			</tr>
		</thead>

	</table>


{% endblock %}
{% block javascripts %}
	{{ parent() }}
	 <script type="text/javascript">
		
		 function printRow(value){
		
	         var url =window.location.origin +"/boncommande/" + value+ "/printrecu"
		        document.location.href=url
		    }
		    function iniTable(){
		        $('#example-table').DataTable({
		            select: true,
		            ordering: true,
		            paging: true,
		            processing: true,
		            serverSide: true,
		            responsive: true,
		            ajax: {
		                url: '{{ path("detailreglement_lister") }}',
		                type: 'GET',
		
		            },
		            columns: [
		                { data: 'datepaiement' },
		                { data: 'reglement.facture.numfacture' },
		                { data: 'reglement.facture.boncommande.client.libelle' },
		                { data: 'reglement.facture.boncommande.client.contact1' },
		                { data: 'reglement.facture.montantht' },
		                { data: 'reglement.facture.montantremise' },
		                { data: 'reglement.facture.tva' },
		                { data: 'reglement.facture.netpayee' },
		                { data: 'montantpaye' },
		                { data: 'reste' }
		 	
		                // { data: 'salary' },
		                // { data: 'office' }
		            ],
		           columnDefs: [
	                {
	                    targets: 10,
	                    data: 'id',
	                    render: function (data, type, row, meta) {
			                        return ' <button class="btn btn-primary" onClick="javascript:printRow('+ data + ')" title="Imprimer" data-bs-target="#" ><i class="fa fa-print"></i></button>';
	
			                    }
	                }
	            ],
		            layout: {
		                topStart: {
		                    pageLength: {
		                        menu: [5, 10, 25, 50, 100]
		                    },
		                    buttons: {
		                        buttons:['copy','excel',  'print', 'pdf','colvis']
		                    }
		
		                }
		            },
		            language: {
		                url: '{{ asset("DataTables/fr-FR.json") }}',
		            }
		        });
		        // $('#example-table-table-table').on( 'draw.dt', function () {
		        //     $('#example-table-table-table').ajax.reload();
		        //     console.log('load')
		        // } );
		
		        const alerts = document.querySelectorAll('[class*="alert-"]')
		        for (const alert of alerts) {
		            setTimeout( function() {
		                const bootstrapAlert = bootstrap.Alert.getOrCreateInstance(alert);
		                bootstrapAlert.close();
		            }, 3000);
		        }
		
		  
		    }
		
		
		        $(document).ready(function(){
		            iniTable()
		
		        });
		</script>
{% endblock %}
